//!
//! \file skl_dynamic_bitset
//!
//! \brief A dynamic size bitset implementation
//!
#pragma once

#if defined(__AVX512F__)
#    include <immintrin.h>
#endif

#include "skl_int"
#include "skl_result"
#include "skl_stream"
#include "skl_vector_if"
#include "skl_utility"
#include "skl_traits/conditional_t"

namespace skl {
template <bool _DefaultBitValue = false, bool _EnableCounting = false, u64 _Alignment = SKL_CACHE_LINE_SIZE>
class DynamicBitSet {
    //! Type of an empty struct (used when a type is not needed)
    struct bitset_empty_t {
        constexpr bitset_empty_t() noexcept = default;
        constexpr bitset_empty_t(u32) noexcept { }
    };

public:
    //! Is the bitset of fixed size
    static constexpr bool CIsFixedSize = false;

    //! Type of the slice
    using slice_t = u64;

    //! Number of bits in a slice
    static constexpr u64 CBitSizeOfSlice = sizeof(slice_t) * 8u;

    //! Bit size of a slice mask
    static constexpr u64 CBitSizeOfSliceMask = CBitSizeOfSlice - 1u;

    static_assert((CBitSizeOfSlice & CBitSizeOfSliceMask) == 0u, "CBitSizeOfSlice must be a power of two");

    //! Default value for the bits (false = 0, true = 1)
    static constexpr bool CDefaultBitValue = _DefaultBitValue;

    //! Default value for a slice (all bits set or cleared based on _DefaultBitValue)
    static constexpr slice_t CDefaultSliceValue = _DefaultBitValue ? ~slice_t(0u) : slice_t(0u);

    //! Container type
    using container_t = skl_vector<slice_t, CVectorIncreaseStep, _Alignment>;

    //! Counter type (only if counting is enabled)
    using counter_t = conditional_t<_EnableCounting, u32, bitset_empty_t>;

    DynamicBitSet() noexcept = default;
    explicit DynamicBitSet(u32 f_bit_size) noexcept
        : m_size(f_bit_size) {
        SKL_ASSERT_CRITICAL(0u < f_bit_size);

        const auto slice_count = integral_ceil<u32>(skl_max<u32>(f_bit_size, 64u), CBitSizeOfSlice);
        m_slices.upgrade().resize(slice_count);

        // Initialize slices
        for (auto& slice : m_slices) {
            slice = CDefaultSliceValue;
        }

        clear_padding_bits();

        // Initialize size
        if constexpr (_EnableCounting && _DefaultBitValue) {
            m_count = f_bit_size;
        }
    }

    //! Get the count of slices
    [[nodiscard]] constexpr u32 slices_count() const noexcept {
        return u32(m_slices.size());
    }

    //! Get the count of set bits
    [[nodiscard]] constexpr slice_t count() const noexcept {
        if constexpr (_EnableCounting) {
            return m_count;
        } else {
            return count_bits();
        }
    }

    //! Get the index of the first bit = _Value
    template <bool _Value>
    [[nodiscard]] constexpr skl_result<u32> find_first() const noexcept {
        if (m_slices.empty()) {
            return skl_fail{SKL_ERR_NOT_FOUND};
        }

#if defined(__AVX512F__)
        // AVX-512 implementation
        const u32 slice_count = u32(m_slices.size());
        const u32 chunks      = slice_count / 8u; // 8 x u64 = 512 bits

        // Process 8 slices at a time using AVX-512
        for (u32 chunk = 0u; chunk < chunks; ++chunk) {
            const u32 base_idx = chunk * 8u;

            // Load 8 u64 slices (512 bits)
            __m512i data = _mm512_loadu_si512(reinterpret_cast<const __m512i*>(&m_slices[base_idx]));

            if constexpr (_Value) {
                // Looking for first 1 bit: find first slice that is NOT all zeros
                __mmask8 mask = _mm512_cmpneq_epu64_mask(data, _mm512_setzero_si512());
                if (mask != 0u) {
                    // Found a slice with at least one 1 bit
                    const u32 slice_offset = __builtin_ctz(mask);
                    const u32 slice_idx    = base_idx + slice_offset;
                    const u64 slice_value  = m_slices[slice_idx];
                    const u32 bit_in_slice = __builtin_ctzll(slice_value);
                    const u32 bit_index    = (slice_idx * CBitSizeOfSlice) + bit_in_slice;

                    if (bit_index < m_size) {
                        return bit_index;
                    }
                }
            } else {
                // Looking for first 0 bit: find first slice that is NOT all ones
                __m512i  all_ones = _mm512_set1_epi64(~0ULL);
                __mmask8 mask     = _mm512_cmpneq_epu64_mask(data, all_ones);
                if (mask != 0u) {
                    // Found a slice with at least one 0 bit
                    const u32 slice_offset = __builtin_ctz(mask);
                    const u32 slice_idx    = base_idx + slice_offset;
                    const u64 slice_value  = m_slices[slice_idx];
                    const u32 bit_in_slice = __builtin_ctzll(~slice_value); // Invert to find first 0
                    const u32 bit_index    = (slice_idx * CBitSizeOfSlice) + bit_in_slice;

                    if (bit_index < m_size) {
                        return bit_index;
                    }
                }
            }
        }

        // Process remaining slices
        for (u32 i = chunks * 8u; i < slice_count; ++i) {
            const slice_t slice_value = m_slices[i];

            if constexpr (_Value) {
                if (slice_value != 0u) {
                    const u32 bit_in_slice = __builtin_ctzll(slice_value);
                    const u32 bit_index    = (i * CBitSizeOfSlice) + bit_in_slice;
                    if (bit_index < m_size) {
                        return bit_index;
                    }
                }
            } else {
                if (slice_value != ~slice_t(0u)) {
                    const u32 bit_in_slice = __builtin_ctzll(~slice_value);
                    const u32 bit_index    = (i * CBitSizeOfSlice) + bit_in_slice;
                    if (bit_index < m_size) {
                        return bit_index;
                    }
                }
            }
        }
#else
        // Standard fallback implementation
        const u32 slice_count = u32(m_slices.size());

        for (u32 i = 0u; i < slice_count; ++i) {
            const slice_t slice_value = m_slices[i];

            if constexpr (_Value) {
                // Looking for first 1 bit
                if (slice_value != 0u) {
                    const u32 bit_in_slice = __builtin_ctzll(slice_value);
                    const u32 bit_index    = (i * CBitSizeOfSlice) + bit_in_slice;
                    if (bit_index < m_size) {
                        return bit_index;
                    }
                }
            } else {
                // Looking for first 0 bit
                if (slice_value != ~slice_t(0u)) {
                    const u32 bit_in_slice = __builtin_ctzll(~slice_value);
                    const u32 bit_index    = (i * CBitSizeOfSlice) + bit_in_slice;
                    if (bit_index < m_size) {
                        return bit_index;
                    }
                }
            }
        }
#endif

        return skl_fail{SKL_ERR_NOT_FOUND}; // Not found
    }

    //! Get the number of bits in the bitset
    [[nodiscard]] constexpr u32 size() const noexcept {
        return m_size;
    }

    //! Set the bit at \p f_index
    //! \return True if the bit was already set, false otherwise
    //! \remark Asserts that \p f_index is valid
    constexpr bool set(u32 f_index) noexcept {
        const u32 slice_index = f_index / CBitSizeOfSlice;
        const u32 bit_index   = f_index & CBitSizeOfSliceMask;

        // Validate index
        SKL_ASSERT_CRITICAL(validate_bit_index(f_index));

        auto& slice = m_slices[slice_index];

        const auto mask      = slice_t(1u) << bit_index;
        const auto old_value = (slice & mask) != 0u;
        if constexpr (_EnableCounting) {
            m_count += u32(false == old_value);
        }
        slice |= mask;

        return old_value;
    }

    //! Unset the bit at \p f_index
    //! \return True if the bit was previously set, false otherwise
    //! \remark Asserts that \p f_index is valid
    constexpr bool unset(u32 f_index) noexcept {
        const u32  slice_index = f_index / CBitSizeOfSlice;
        const auto bit_index   = f_index & CBitSizeOfSliceMask;

        // Validate index
        SKL_ASSERT_CRITICAL(validate_bit_index(f_index));

        auto& slice = m_slices[slice_index];

        const auto mask      = slice_t(1u) << bit_index;
        const auto old_value = (slice & mask) != 0u;
        if constexpr (_EnableCounting) {
            m_count -= u32(old_value);
        }
        slice &= ~mask;

        return old_value;
    }

    //! Test if the bit at \p f_index is set
    //! \remark Asserts that \p f_index is valid
    [[nodiscard]] constexpr bool test(u32 f_index) const noexcept {
        const u32  slice_index = f_index / CBitSizeOfSlice;
        const auto bit_index   = f_index & CBitSizeOfSliceMask;

        // Validate index
        SKL_ASSERT_CRITICAL(validate_bit_index(f_index));

        const auto& slice = m_slices[slice_index];
        const auto  mask  = slice_t(1u) << bit_index;
        return (slice & mask) != 0u;
    }

    //! Reset the bitset (set all bits to default value)
    constexpr void reset() noexcept {
        for (auto& slice : m_slices) {
            slice = CDefaultSliceValue;
        }

        clear_padding_bits();

        if constexpr (_EnableCounting) {
            if constexpr (_DefaultBitValue) {
                m_count = m_size;
            } else {
                m_count = 0u;
            }
        }
    }

    //! Flip all bits in the bitset
    constexpr void flip_all() noexcept {
        for (auto& slice : m_slices) {
            slice = ~slice;
        }

        clear_padding_bits();

        if constexpr (_EnableCounting) {
            m_count = u32(m_size - m_count);
        }
    }

    //! Set all bits to \p _Value
    template <bool _Value>
    constexpr void set_all_to() noexcept {
        static constexpr slice_t CValue = _Value ? ~slice_t(0u) : slice_t(0u);
        for (auto& slice : m_slices) {
            slice = CValue;
        }

        clear_padding_bits();

        if constexpr (_EnableCounting) {
            m_count = u32(_Value ? m_size : 0u);
        }
    }

    //! Set all bits to \p f_value
    constexpr void set_all_to(bool f_value) noexcept {
        const slice_t value = f_value ? ~slice_t(0u) : slice_t(0u);
        for (auto& slice : m_slices) {
            slice = value;
        }

        clear_padding_bits();

        if constexpr (_EnableCounting) {
            m_count = u32(f_value ? m_size : 0u);
        }
    }

    //! Get the slice at \p f_index
    [[nodiscard]] constexpr slice_t& slice(u32 f_index) noexcept {
        SKL_ASSERT(f_index < slices_count());
        return m_slices[f_index];
    }

    //! Get the slice at \p f_index
    [[nodiscard]] constexpr const slice_t& slice(u32 f_index) const noexcept {
        SKL_ASSERT(f_index < slices_count());
        return m_slices[f_index];
    }

    //! Are all the bits of this bitset equal to the bits of \p f_other
    [[nodiscard]] constexpr bool operator==(const DynamicBitSet& f_other) const noexcept {
        if (m_size != f_other.m_size) {
            return false;
        }

        const u32 slice_count = slices_count();
        if (slice_count != f_other.slices_count()) {
            return false;
        }

        for (u32 i = 0u; i < slice_count; ++i) {
            if (m_slices[i] != f_other.m_slices[i]) {
                return false;
            }
        }

        return true;
    }

    //! Compare this bitset with \p f_other, first by size then as if both were big unsigned integers
    //! \return Negative if this is smaller, 0 if equal, positive if this is greater
    [[nodiscard]] constexpr i32 compare(const DynamicBitSet& f_other) const noexcept {
        if (m_size != f_other.m_size) {
            return (m_size < f_other.m_size) ? -1 : 1;
        }

        const u32 slice_count = slices_count();
        if (slice_count != f_other.slices_count()) {
            return (slice_count < f_other.slices_count()) ? -1 : 1;
        }

        // Walk the slices from the most significant one to the least significant one
        for (u32 i = slice_count; i > 0u; --i) {
            const auto index = i - 1u;
            if (m_slices[index] != f_other.m_slices[index]) {
                return (m_slices[index] < f_other.m_slices[index]) ? -1 : 1;
            }
        }

        return 0;
    }

    [[nodiscard]] constexpr bool operator<(const DynamicBitSet& f_other) const noexcept {
        return compare(f_other) < 0;
    }

    [[nodiscard]] constexpr bool operator>(const DynamicBitSet& f_other) const noexcept {
        return compare(f_other) > 0;
    }

    [[nodiscard]] constexpr bool operator<=(const DynamicBitSet& f_other) const noexcept {
        return compare(f_other) <= 0;
    }

    [[nodiscard]] constexpr bool operator>=(const DynamicBitSet& f_other) const noexcept {
        return compare(f_other) >= 0;
    }

    //! Compute a 64bit hash of the bits (the size is part of the hash)
    [[nodiscard]] constexpr u64 hash_u64() const noexcept {
        const u32 slice_count = slices_count();

        u64 hash = u64((CHashOffsetBasis ^ u64(m_size)) * CHashPrime);
        for (u32 i = 0u; i < slice_count; ++i) {
            hash = u64((hash ^ u64(m_slices[i])) * CHashPrime);
        }

        return hash;
    }

    //! Compute a 32bit hash of the bits (the size is part of the hash)
    [[nodiscard]] constexpr u32 hash_u32() const noexcept {
        const auto hash = hash_u64();
        return u32(hash ^ (hash >> 32u));
    }

    //! Compute a 16bit hash of the bits (the size is part of the hash)
    [[nodiscard]] constexpr u16 hash_u16() const noexcept {
        const auto hash = hash_u32();
        return u16(hash ^ (hash >> 16u));
    }

    //! Is at least one bit set
    [[nodiscard]] constexpr bool any() const noexcept {
        // The padding bits are always cleared, no masking needed
        const u32 slice_count = slices_count();
        for (u32 i = 0u; i < slice_count; ++i) {
            if (m_slices[i] != slice_t(0u)) {
                return true;
            }
        }

        return false;
    }

    //! Are all the bits cleared
    [[nodiscard]] constexpr bool none() const noexcept {
        return false == any();
    }

    //! Are all the bits set
    [[nodiscard]] constexpr bool all() const noexcept {
        const u32  slice_count  = slices_count();
        const auto padding_mask = padding_bits_mask();

        for (u32 i = 0u; i < slice_count; ++i) {
            auto slice_value = m_slices[i];

            // The padding bits are always cleared, ignore them
            if (i == (slice_count - 1u)) {
                slice_value |= padding_mask;
            }

            if (slice_value != slice_t(~slice_t(0u))) {
                return false;
            }
        }

        return true;
    }

    //! Flip the bit at \p f_index
    //! \return The new value of the bit
    //! \remark Asserts that \p f_index is valid
    constexpr bool flip(u32 f_index) noexcept {
        if (test(f_index)) {
            (void)unset(f_index);
            return false;
        }

        (void)set(f_index);
        return true;
    }

    //! Set the bit at \p f_index to \p f_value
    //! \return True if the bit was previously set, false otherwise
    //! \remark Asserts that \p f_index is valid
    constexpr bool assign(u32 f_index, bool f_value) noexcept {
        return f_value ? set(f_index) : unset(f_index);
    }

    //! Get the index of the first bit = _Value at or after \p f_from
    template <bool _Value>
    [[nodiscard]] constexpr skl_result<u32> find_first_from(u32 f_from) const noexcept {
        if (f_from >= m_size) {
            return skl_fail{SKL_ERR_NOT_FOUND};
        }

        const u32 slice_count = slices_count();
        const u32 start_slice = f_from / CBitSizeOfSlice;
        const u32 start_bit   = f_from & CBitSizeOfSliceMask;

        for (u32 i = start_slice; i < slice_count; ++i) {
            // When hunting for a cleared bit, hunt for a set bit in the inverse
            auto slice_value = _Value ? m_slices[i] : slice_t(~m_slices[i]);

            // Skip the bits before the start bit
            if (i == start_slice) {
                slice_value &= slice_t(~slice_t(0u) << start_bit);
            }

            if (slice_value != slice_t(0u)) {
                const u32 bit_index = u32((i * CBitSizeOfSlice) + u32(__builtin_ctzll(slice_value)));

                // Only the padding bits of the last slice can land past the size
                return (bit_index < m_size) ? skl_result<u32>{bit_index} : skl_result<u32>{skl_fail{SKL_ERR_NOT_FOUND}};
            }
        }

        return skl_fail{SKL_ERR_NOT_FOUND};
    }

    //! Get the index of the last bit = _Value
    template <bool _Value>
    [[nodiscard]] constexpr skl_result<u32> find_last() const noexcept {
        const auto padding_mask = padding_bits_mask();

        for (u32 i = slices_count(); i > 0u; --i) {
            const u32 index = i - 1u;

            // When hunting for a cleared bit, hunt for a set bit in the inverse
            auto slice_value = _Value ? m_slices[index] : slice_t(~m_slices[index]);

            // Never report a padding bit
            if (index == (slices_count() - 1u)) {
                slice_value &= slice_t(~padding_mask);
            }

            if (slice_value != slice_t(0u)) {
                const u32 highest_bit = 63u - u32(__builtin_clzll(slice_value));
                return u32((index * CBitSizeOfSlice) + highest_bit);
            }
        }

        return skl_fail{SKL_ERR_NOT_FOUND};
    }

    //! Call \p f_callback(u32 f_bit_index) for each set bit, from the lowest index to the highest
    template <typename _Functor>
    constexpr void for_each_set_bit(_Functor&& f_callback) const noexcept {
        // The padding bits are always cleared, they can never be reported
        const u32 slice_count = slices_count();
        for (u32 i = 0u; i < slice_count; ++i) {
            auto slice_value = m_slices[i];
            while (slice_value != slice_t(0u)) {
                const u32 bit_index = u32(__builtin_ctzll(slice_value));
                f_callback(u32((i * CBitSizeOfSlice) + bit_index));

                // Clear the lowest set bit
                slice_value &= slice_t(slice_value - 1u);
            }
        }
    }

    //! Does this bitset have at least one bit in common with \p f_other
    //! \remark Asserts that both bitsets have the same size
    [[nodiscard]] constexpr bool intersects(const DynamicBitSet& f_other) const noexcept {
        SKL_ASSERT(m_size == f_other.m_size);

        const u32 slice_count = slices_count();
        for (u32 i = 0u; i < slice_count; ++i) {
            if ((m_slices[i] & f_other.m_slices[i]) != slice_t(0u)) {
                return true;
            }
        }

        return false;
    }

    //! Are all the bits set in this bitset also set in \p f_other
    //! \remark Asserts that both bitsets have the same size
    [[nodiscard]] constexpr bool is_subset_of(const DynamicBitSet& f_other) const noexcept {
        SKL_ASSERT(m_size == f_other.m_size);

        const u32 slice_count = slices_count();
        for (u32 i = 0u; i < slice_count; ++i) {
            if ((m_slices[i] & ~f_other.m_slices[i]) != slice_t(0u)) {
                return false;
            }
        }

        return true;
    }

    //! Bitwise AND with \p f_other
    //! \remark Asserts that both bitsets have the same size
    //! \remark The padding bits stay cleared, no masking needed
    constexpr DynamicBitSet& operator&=(const DynamicBitSet& f_other) noexcept {
        SKL_ASSERT(m_size == f_other.m_size);

        const u32 slice_count = slices_count();
        for (u32 i = 0u; i < slice_count; ++i) {
            m_slices[i] &= f_other.m_slices[i];
        }

        if constexpr (_EnableCounting) {
            m_count = u32(count_bits());
        }

        return *this;
    }

    //! Bitwise OR with \p f_other
    //! \remark Asserts that both bitsets have the same size
    //! \remark The padding bits stay cleared, no masking needed
    constexpr DynamicBitSet& operator|=(const DynamicBitSet& f_other) noexcept {
        SKL_ASSERT(m_size == f_other.m_size);

        const u32 slice_count = slices_count();
        for (u32 i = 0u; i < slice_count; ++i) {
            m_slices[i] |= f_other.m_slices[i];
        }

        if constexpr (_EnableCounting) {
            m_count = u32(count_bits());
        }

        return *this;
    }

    //! Bitwise XOR with \p f_other
    //! \remark Asserts that both bitsets have the same size
    //! \remark The padding bits stay cleared, no masking needed
    constexpr DynamicBitSet& operator^=(const DynamicBitSet& f_other) noexcept {
        SKL_ASSERT(m_size == f_other.m_size);

        const u32 slice_count = slices_count();
        for (u32 i = 0u; i < slice_count; ++i) {
            m_slices[i] ^= f_other.m_slices[i];
        }

        if constexpr (_EnableCounting) {
            m_count = u32(count_bits());
        }

        return *this;
    }

    //! Swap the content of this bitset with \p f_other
    void swap(DynamicBitSet& f_other) noexcept {
        container_t slices{static_cast<container_t&&>(m_slices)};
        m_slices         = static_cast<container_t&&>(f_other.m_slices);
        f_other.m_slices = static_cast<container_t&&>(slices);

        const auto size = m_size;
        m_size          = f_other.m_size;
        f_other.m_size  = size;

        if constexpr (_EnableCounting) {
            const auto count = m_count;
            m_count          = f_other.m_count;
            f_other.m_count  = count;
        }
    }

    //! Reserve storage for at least \p f_bit_size bits (does not change the size)
    void reserve(u32 f_bit_size) noexcept {
        if (f_bit_size == 0u) {
            return;
        }

        m_slices.upgrade().reserve(integral_ceil<u32>(f_bit_size, CBitSizeOfSlice));
    }

    //! Shrink the bitset to \p f_new_size, dropping every bit at or above it
    //! \remark Does nothing if \p f_new_size is not smaller than the current size
    void shrink(u32 f_new_size) noexcept {
        if (f_new_size >= m_size) {
            return;
        }

        if (f_new_size == 0u) {
            clear();
            return;
        }

        const auto new_slice_count = integral_ceil<u32>(f_new_size, CBitSizeOfSlice);
        if (new_slice_count < slices_count()) {
            m_slices.upgrade().resize(new_slice_count);
        }

        m_size = f_new_size;

        clear_padding_bits();

        if constexpr (_EnableCounting) {
            m_count = u32(count_bits());
        }
    }

    //! Resize the bitset to \p f_new_size, growing or shrinking as needed
    void resize(u32 f_new_size) noexcept {
        if (f_new_size > m_size) {
            grow(f_new_size);
        } else {
            shrink(f_new_size);
        }
    }

    //! Grow the bitset to the specified size
    //! \param f_new_size Minimum new size of the bitset
    constexpr void grow(u32 f_new_size) noexcept {
        // If new size is less than or equal to current size, do nothing
        if (f_new_size <= m_size) {
            return;
        }

        // The bits about to be exposed must start from the default value
        clear_padding_bits();

        // Calculate new slice count
        const auto new_slice_count     = integral_ceil<u32>(f_new_size, CBitSizeOfSlice);
        const auto current_slice_count = m_slices.size();

        // Resize slices if needed
        if (new_slice_count > current_slice_count) {
            m_slices.upgrade().resize(new_slice_count, CDefaultSliceValue);
        }

        // If growing and need to set new bits
        if constexpr (_DefaultBitValue) {
            if (new_slice_count == current_slice_count) {
                // Same slice count, just need to set bits in the last slice
                const auto delta = f_new_size - m_size;

                if ((delta > 0u) && (delta < CBitSizeOfSlice)) {
                    // Partial slice - set specific bits
                    const auto start_bit  = m_size & CBitSizeOfSliceMask;
                    const auto mask       = slice_t(slice_t((slice_t(1u) << delta) - 1u) << start_bit);
                    m_slices.back()      |= mask;
                }
                // If delta == CBitSizeOfSlice: slice already initialized to default, just update count
                // If delta == 0: nothing to do

                if constexpr (_EnableCounting) {
                    m_count += delta;
                }
            } else {
                if (m_size > 0u) {
                    const auto used_bits_modulo                 = (m_size & CBitSizeOfSliceMask);
                    // If modulo is 0, last slice is fully used (64 bits), not empty
                    const auto used_bits_in_last_existing_slice = (used_bits_modulo == 0u) ? CBitSizeOfSlice : used_bits_modulo;
                    const auto unused_bits_in_last_slice        = CBitSizeOfSlice - used_bits_in_last_existing_slice;

                    if (unused_bits_in_last_slice > 0u) {
                        const auto last_existing_slice_mask   = ~slice_t((slice_t(1u) << used_bits_in_last_existing_slice) - 1u);
                        const auto last_existing_slice_index  = current_slice_count - 1u;
                        m_slices[last_existing_slice_index]  |= last_existing_slice_mask;
                        if constexpr (_EnableCounting) {
                            m_count += unused_bits_in_last_slice;
                        }
                    }
                }

                const auto CLeftOverBits = f_new_size & CBitSizeOfSliceMask;
                if (CLeftOverBits > 0u) {
                    const auto CLeftOverBitsMask = slice_t(slice_t(slice_t(1u) << CLeftOverBits) - 1u);
                    for (u32 i = current_slice_count; i < new_slice_count; ++i) {
                        const auto is_last = (i == (new_slice_count - 1u));
                        if (is_last) {
                            m_slices[i] |= CLeftOverBitsMask;
                            if constexpr (_EnableCounting) {
                                m_count += CLeftOverBits;
                            }
                        } else {
                            m_slices[i] = CDefaultSliceValue;
                            if constexpr (_EnableCounting) {
                                m_count += CBitSizeOfSlice;
                            }
                        }
                    }
                } else {
                    for (u32 i = current_slice_count; i < new_slice_count; ++i) {
                        m_slices[i] = CDefaultSliceValue;
                    }

                    if constexpr (_EnableCounting) {
                        m_count += (new_slice_count - current_slice_count) * CBitSizeOfSlice;
                    }
                }
            }
        }

        // Update size
        m_size = f_new_size;

        clear_padding_bits();
    }

    //! Clear the bitset (removes all slices)
    void clear() noexcept {
        m_slices.upgrade().clear();
        m_size = 0u;
        if constexpr (_EnableCounting) {
            m_count = 0u;
        }
    }

    //! Serialize the bitset to a stream
    void serialize(skl_stream& f_stream) const noexcept {
        const u32 slice_count = slices_count();
        f_stream.write_unsafe(&m_size, sizeof(m_size));
        f_stream.write_unsafe(&slice_count, sizeof(slice_count));
        if (slice_count > 0u) {
            f_stream.write_unsafe(m_slices.data(), slice_count * u32(sizeof(slice_t)));
        }
    }

    //! Deserialize the bitset from a stream
    void deserialize(skl_stream& f_stream) noexcept {
        m_size                = f_stream.read<u32>();
        const u32 slice_count = f_stream.read<u32>();

        // The slices must be able to hold all the bits (the stream is not trusted)
        SKL_ASSERT_PERMANENT(u64(slice_count) * CBitSizeOfSlice >= u64(m_size));

        m_slices.upgrade().resize(slice_count);
        if (slice_count > 0u) {
            SKL_ASSERT_PERMANENT(f_stream.read(reinterpret_cast<byte*>(m_slices.data()), slice_count * u32(sizeof(slice_t))));
        }

        clear_padding_bits();

        if constexpr (_EnableCounting) {
            m_count = u32(count_bits());
        }
    }

private:
    //! Count the set bits by inspecting the slices (ignores the cached counter)
    [[nodiscard]] constexpr slice_t count_bits() const noexcept {
        slice_t set_count = 0u;
        for (const auto slice : m_slices) {
            set_count += slice_t(__builtin_popcountll(slice));
        }

        return set_count;
    }

    //! Get the mask of the unused (padding) bits in the last slice (0 if none)
    [[nodiscard]] constexpr slice_t padding_bits_mask() const noexcept {
        const auto padding_count = padding_bits_count();
        if (padding_count == 0u) {
            return slice_t(0u);
        }

        return slice_t(~slice_t(slice_t(slice_t(1u) << (CBitSizeOfSlice - padding_count)) - 1u));
    }

    //! FNV-1a hash constants
    static constexpr u64 CHashOffsetBasis = 14695981039346656037ull;
    static constexpr u64 CHashPrime       = 1099511628211ull;

    //! Get the number of unused (padding) bits in the last slice (0 if none)
    [[nodiscard]] constexpr u64 padding_bits_count() const noexcept {
        const auto total_bits = u64(m_slices.size()) * CBitSizeOfSlice;
        SKL_ASSERT(total_bits >= u64(m_size));
        return total_bits - u64(m_size);
    }

    //! Clear the unused (padding) bits in the last slice
    //! \remark Keeps the raw slice data canonical so it can be safely compared, hashed, serialized or grown into
    constexpr void clear_padding_bits() noexcept {
        const auto padding_count = padding_bits_count();
        if (padding_count == 0u) {
            return;
        }

        // A slice can never be fully padding
        SKL_ASSERT(padding_count < CBitSizeOfSlice);

        const auto used_bits  = CBitSizeOfSlice - padding_count;
        m_slices.back()      &= slice_t(slice_t(slice_t(1u) << used_bits) - 1u);
    }

#if SKL_BUILD_DEV
    [[nodiscard]] constexpr bool validate_bit_index(u32 f_index) const noexcept {
        const u32  slice_index   = f_index / CBitSizeOfSlice;
        const u32  bit_index     = f_index & CBitSizeOfSliceMask;
        const u32  slice_count   = m_slices.size();
        // Leftover bits = total allocated bits - valid bits
        const auto CLeftOverBits = (slice_count * CBitSizeOfSlice) - m_size;

        return ((slice_index < slice_count)
                && ((slice_index < (slice_count - 1u))
                    || (bit_index < (CBitSizeOfSlice - CLeftOverBits))));
    }
#else
    static constexpr bool validate_bit_index(u32 f_index) noexcept {
        return true;
    }
#endif

private:
    container_t                     m_slices;    //!< Slices of the bitset
    u32                             m_size{0u};  //!< Number of bits in the bitset
    [[no_unique_address]] counter_t m_count{0u}; //!< Count of set bits (only if counting is enabled)
};

//! Hash functor for any DynamicBitSet
struct dynamic_bitset_hash {
    template <bool _DefaultBitValue, bool _EnableCounting, u64 _Alignment>
    [[nodiscard]] static u64 operator()(const DynamicBitSet<_DefaultBitValue, _EnableCounting, _Alignment>& f_bitset) noexcept {
        return f_bitset.hash_u64();
    }
};
